<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- MSTest Configuration -->
  <MSTest>
    <!-- Enable parallel test execution at class level -->
    <Parallelize>
      <Workers>4</Workers> <!-- Use 4 workers for balanced performance -->
      <Scope>ClassLevel</Scope> <!-- Run test classes in parallel -->
    </Parallelize>
    <!-- Reduced test timeout - most tests should complete in seconds -->
    <TestTimeout>30000</TestTimeout> <!-- 30 seconds per test (increased from 5 minutes) -->
  </MSTest>
  
  <!-- Test Run Parameters -->
  <RunConfiguration>
    <!-- Maximum number of parallel test workers -->
    <MaxCpuCount>4</MaxCpuCount> <!-- Use 4 CPU cores for balanced parallelization -->
    
    <!-- Disable app domains for better performance -->
    <DisableAppDomain>true</DisableAppDomain>
    
    <!-- Overall test session timeout -->
    <TestSessionTimeout>480000</TestSessionTimeout> <!-- 8 minutes for entire test session (5 + 3 minutes buffer) -->
    
    <!-- Disable parallelization for debugging -->
    <!-- <DisableParallelization>false</DisableParallelization> -->
  </RunConfiguration>
</RunSettings>
