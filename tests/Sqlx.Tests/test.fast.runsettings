<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- Fast Test Configuration - Optimized for speed -->
  <MSTest>
    <!-- Balanced parallel test execution (4 workers) -->
    <Parallelize>
      <Workers>4</Workers> <!-- Use 4 workers for balanced performance -->
      <Scope>ClassLevel</Scope>
    </Parallelize>
    <!-- Timeout for test execution -->
    <TestTimeout>30000</TestTimeout> <!-- 30 seconds per test (increased for stability) -->
  </MSTest>
  
  <RunConfiguration>
    <!-- Use 4 CPU cores for balanced parallelization -->
    <MaxCpuCount>4</MaxCpuCount>
    
    <!-- Performance optimizations -->
    <DisableAppDomain>true</DisableAppDomain>
    
    <!-- 6 minute total timeout (3 minutes + 3 minutes buffer) -->
    <TestSessionTimeout>360000</TestSessionTimeout>
    
    <!-- Collect minimal data -->
    <ResultsDirectory>./TestResults</ResultsDirectory>
  </RunConfiguration>
  
  <!-- Data Collection - Minimal for speed -->
  <DataCollectionRunSettings>
    <DataCollectors>
      <!-- Disable code coverage for faster execution -->
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
